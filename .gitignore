# =============================================================
# MuST Platform — Root .gitignore
# Repo root: /home/admin-yash/Desktop/Decode
# =============================================================

# -------------------------------------------------------------
# Rust build artifacts  (all sub-projects)
# -------------------------------------------------------------
**/target/
Cargo.lock          # not ignored — keep for binary projects
# If this were a library workspace, you'd ignore Cargo.lock.
# For executables (simulator-engine, telemetry-gateway) keep it.

# Rust incremental / debug artefacts
**/*.pdb
**/*.d

# -------------------------------------------------------------
# Protobuf generated files  (re-generated by build.rs)
# -------------------------------------------------------------
**/OUT_DIR/
# specific generated file patterns if ever written outside target
**/*.pb.go
**/*.pb.rs          # generated by tonic-build inside target/ already

# -------------------------------------------------------------
# simulator-engine — sample data (large binary files)
# -------------------------------------------------------------
simulator-engine/data/

# -------------------------------------------------------------
# simulator-ui  (Vite / Node.js frontend)
# -------------------------------------------------------------
simulator-ui/node_modules/
simulator-ui/dist/
simulator-ui/dist-ssr/
simulator-ui/.vite/
simulator-ui/*.local

# -------------------------------------------------------------
# bin/  (pre-built protoc binary — large, platform-specific)
# -------------------------------------------------------------
bin/

# -------------------------------------------------------------
# Logs
# -------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------------------------------------------
# Editor / IDE
# -------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sw?
.DS_Store
Thumbs.db

# -------------------------------------------------------------
# Environment / secrets
# -------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# -------------------------------------------------------------
# OS generated
# -------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# -------------------------------------------------------------
# Docker
# -------------------------------------------------------------
# Keep docker-compose files tracked; ignore override
docker-compose.override.yml
